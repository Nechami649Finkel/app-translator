<h3><span id="&#x5DE;&#x5E2;&#x5E8;&#x5DB;&#x5EA;_&#x5D4;&#x5E4;&#x5E2;&#x5DC;&#x5D4;_Windows:"></span><span class="mw-headline" id=".D7.9E.D7.A2.D7.A8.D7.9B.D7.AA_.D7.94.D7.A4.D7.A2.D7.9C.D7.94_Windows:">&#x5DE;&#x5E2;&#x5E8;&#x5DB;&#x5EA; &#x5D4;&#x5E4;&#x5E2;&#x5DC;&#x5D4; Windows:</span></h3>
<h4><span id="&#x5D4;&#x5EA;&#x5E7;&#x5E0;&#x5D4;_&#x5D1;&#x5E6;&#x5D5;&#x5E8;&#x5D4;_&#x5E0;&#x5E4;&#x5D5;&#x5E6;&#x5D4;:"></span><span class="mw-headline" id=".D7.94.D7.AA.D7.A7.D7.A0.D7.94_.D7.91.D7.A6.D7.95.D7.A8.D7.94_.D7.A0.D7.A4.D7.95.D7.A6.D7.94:">&#x5D4;&#x5EA;&#x5E7;&#x5E0;&#x5D4; &#x5D1;&#x5E6;&#x5D5;&#x5E8;&#x5D4; &#x5E0;&#x5E4;&#x5D5;&#x5E6;&#x5D4;:</span></h4>
<p><a href="/wiki/%D7%94%D7%AA%D7%A7%D7%A0%D7%AA_%D7%AA%D7%A2%D7%95%D7%93%D7%94_%D7%A0%D7%A4%D7%95%D7%A6%D7%94" title="&#x5D4;&#x5EA;&#x5E7;&#x5E0;&#x5EA; &#x5EA;&#x5E2;&#x5D5;&#x5D3;&#x5D4; &#x5E0;&#x5E4;&#x5D5;&#x5E6;&#x5D4;">&#x5DC;&#x5D7;&#x5E6;&#x5D5; &#x5DB;&#x5D0;&#x5DF; &#x5DB;&#x5D3;&#x5D9; &#x5DC;&#x5D4;&#x5EA;&#x5E7;&#x5D9;&#x5DF; &#x5D0;&#x5EA; &#x5D4;&#x5EA;&#x5E2;&#x5D5;&#x5D3;&#x5D4; &#x5D1;&#x5E6;&#x5D5;&#x5E8;&#x5D4; &#x5D4;&#x5E0;&#x5E4;&#x5D5;&#x5E6;&#x5D4;</a>
</p>
<div class="alert alert-danger" role="alert" style="margin-top: 1rem; color: #842029; background-color: #f8d7da; border-color: #f5c2c7; position: relative; padding: 1rem 1rem; margin-bottom: 1rem; border: 1px solid transparent; border-radius: .25rem;">
<p>&#x1F6A8;
<strong></strong>  &#x5D9;&#x5E9; &#x5DC;&#x5D4;&#x5EA;&#x5E7;&#x5D9;&#x5DF; &#x5D0;&#x5EA; &#x5D4;&#x5EA;&#x5E2;&#x5D5;&#x5D3;&#x5D4; &#x5D1;&#x5DB;&#x5DC; &#x5DE;&#x5D7;&#x5E9;&#x5D1; &#x5E9;&#x5DE;&#x5D7;&#x5D5;&#x5D1;&#x5E8; &#x5DC;&#x5E0;&#x5D8;&#x5E4;&#x5E8;&#x5D9; &#x5D1;&#x5E4;&#x5E0;&#x5D9; &#x5E2;&#x5E6;&#x5DE;&#x5D5;!
</p>
</div>
<p><br>
</p>
<h4><span id="&#x5D4;&#x5EA;&#x5E7;&#x5E0;&#x5D4;_&#x5D9;&#x5D3;&#x5E0;&#x5D9;&#x5EA;:"></span><span class="mw-headline" id=".D7.94.D7.AA.D7.A7.D7.A0.D7.94_.D7.99.D7.93.D7.A0.D7.99.D7.AA:">&#x5D4;&#x5EA;&#x5E7;&#x5E0;&#x5D4; &#x5D9;&#x5D3;&#x5E0;&#x5D9;&#x5EA;:</span></h4>
<p>&#x5D1;&#x5DE;&#x5D9;&#x5D3;&#x5D4; &#x5D5;&#x5D4;&#x5D4;&#x5EA;&#x5E7;&#x5E0;&#x5D4; &#x5D4;&#x5E8;&#x5D2;&#x5D9;&#x5DC;&#x5D4; &#x5DC;&#x5D0; &#x5E2;&#x5D5;&#x5D1;&#x5D3;&#x5EA;, &#x5D9;&#x5E9; &#x5DC;&#x5E0;&#x5E1;&#x5D5;&#x5EA; &#x5DC;&#x5D4;&#x5EA;&#x5E7;&#x5D9;&#x5DF; &#x5D9;&#x5D3;&#x5E0;&#x5D9;&#x5EA; &#x5D0;&#x5EA; &#x5D4;&#x5EA;&#x5E2;&#x5D5;&#x5D3;&#x5D5;&#x5EA;.<br>
&#x5DC;&#x5E4;&#x5D9; &#x5D4;&#x5D4;&#x5D5;&#x5E8;&#x5D0;&#x5D5;&#x5EA; &#x5D1;&#x5DE;&#x5D3;&#x5E8;&#x5D9;&#x5DA; &#x5DC;&#x5D4;&#x5EA;&#x5E7;&#x5E0;&#x5EA; &#x5D4;&#x5EA;&#x5E2;&#x5D5;&#x5D3;&#x5D4; &#x5D9;&#x5D3;&#x5E0;&#x5D9;&#x5EA;:<br>
<a href="/wiki/%D7%94%D7%AA%D7%A7%D7%A0%D7%AA_%D7%AA%D7%A2%D7%95%D7%93%D7%94_%D7%99%D7%93%D7%A0%D7%99%D7%AA_%D7%91%D7%9E%D7%97%D7%A9%D7%91_-_%D7%97%D7%93%D7%A9_2" title="&#x5D4;&#x5EA;&#x5E7;&#x5E0;&#x5EA; &#x5EA;&#x5E2;&#x5D5;&#x5D3;&#x5D4; &#x5D9;&#x5D3;&#x5E0;&#x5D9;&#x5EA; &#x5D1;&#x5DE;&#x5D7;&#x5E9;&#x5D1; - &#x5D7;&#x5D3;&#x5E9; 2">&#x5D4;&#x5EA;&#x5E7;&#x5E0;&#x5EA; &#x5EA;&#x5E2;&#x5D5;&#x5D3;&#x5D4; &#x5D9;&#x5D3;&#x5E0;&#x5D9;&#x5EA; &#x5D1;&#x5DE;&#x5D7;&#x5E9;&#x5D1; - &#x5D7;&#x5D3;&#x5E9; 2</a>
</p>
<hr>
<h3><span id="&#x5DC;&#x5D9;&#x5E0;&#x5D5;&#x5E7;&#x5E1;:"></span><span class="mw-headline" id=".D7.9C.D7.99.D7.A0.D7.95.D7.A7.D7.A1:">&#x5DC;&#x5D9;&#x5E0;&#x5D5;&#x5E7;&#x5E1;:</span></h3>
<h4><span id="&#x5D4;&#x5EA;&#x5E7;&#x5E0;&#x5D4;_&#x5DB;&#x5DC;&#x5DC;&#x5D9;&#x5EA;_&#x5D1;&#x5DC;&#x5D9;&#x5E0;&#x5D5;&#x5E7;&#x5E1;:"></span><span class="mw-headline" id=".D7.94.D7.AA.D7.A7.D7.A0.D7.94_.D7.9B.D7.9C.D7.9C.D7.99.D7.AA_.D7.91.D7.9C.D7.99.D7.A0.D7.95.D7.A7.D7.A1:">&#x5D4;&#x5EA;&#x5E7;&#x5E0;&#x5D4; &#x5DB;&#x5DC;&#x5DC;&#x5D9;&#x5EA; &#x5D1;&#x5DC;&#x5D9;&#x5E0;&#x5D5;&#x5E7;&#x5E1;:</span></h4>
<p>&#x5D9;&#x5E9; &#x5DC;&#x5D4;&#x5E9;&#x5EA;&#x5DE;&#x5E9; &#x5D1;&#x5E4;&#x5E7;&#x5D5;&#x5D3;&#x5D4; &#x5DE;&#x5D9;&#x5D5;&#x5D7;&#x5D3;&#x5EA; &#x5DC;&#x5EA;&#x5E2;&#x5D5;&#x5D3;&#x5D5;&#x5EA; &#x5D0;&#x5DC;&#x5D5;:
</p>
<pre dir="ltr">curl -sL https://netfree.link/cacert/united/x2/unix.sh | sudo sh
</pre>
<p>&#x5DC;&#x5E4;&#x5E2;&#x5DE;&#x5D9;&#x5DD; &#x5D4;&#x5E4;&#x5E7;&#x5D5;&#x5D3;&#x5D4; <code>curl</code> &#x5DC;&#x5D0; &#x5E7;&#x5D9;&#x5D9;&#x5DE;&#x5EA; &#x5D1;&#x5DE;&#x5E2;&#x5E8;&#x5DB;&#x5EA;, &#x5D5;&#x5D1;&#x5DE;&#x5E7;&#x5E8;&#x5D4; &#x5DB;&#x5D6;&#x5D4; &#x5D4;&#x5E4;&#x5E7;&#x5D5;&#x5D3;&#x5D4; &#x5EA;&#x5D9;&#x5DB;&#x5E9;&#x5DC; &#x5E2;&#x5DD; &#x5DE;&#x5E1;&#x5E8;: <code>Command &apos;curl&apos; not found</code>. &#x5D4;&#x5E4;&#x5EA;&#x5E8;&#x5D5;&#x5DF; &#x5D4;&#x5D5;&#x5D0; &#x5DC;&#x5D4;&#x5EA;&#x5E7;&#x5D9;&#x5DF; curl &#x5E2;&quot;&#x5D9; &#x5D4;&#x5E4;&#x5E7;&#x5D5;&#x5D3;&#x5D4; &#x5D4;&#x5D1;&#x5D0;&#x5D4;:
</p>
<pre dir="ltr"> sudo sh -c &quot;(apt update &amp;&amp; apt install -y curl) || yum install -y curl || apk add curl&quot;
</pre>
<p>&#x5D5;&#x5D0;&#x5D7;&quot;&#x5DB; &#x5DC;&#x5D4;&#x5E8;&#x5D9;&#x5E5; &#x5E9;&#x5D5;&#x5D1; &#x5D0;&#x5EA; &#x5D4;&#x5E7;&#x5D5;&#x5D3;.
</p>
<h4><span id="&#x5D4;&#x5EA;&#x5E7;&#x5E0;&#x5D4;_&#x5D1;&#x5D3;&#x5E4;&#x5D3;&#x5E4;&#x5DF;_&#x5DB;&#x5E8;&#x5D5;&#x5DD;,_&#x5D0;&#x5D3;&#x5D2;&apos;,_&#x5E4;&#x5D9;&#x5D9;&#x5E8;&#x5E4;&#x5D5;&#x5E7;&#x5E1;,_&#x5D1;&#x5DC;&#x5D9;&#x5E0;&#x5D5;&#x5E7;&#x5E1;:"></span><span class="mw-headline" id=".D7.94.D7.AA.D7.A7.D7.A0.D7.94_.D7.91.D7.93.D7.A4.D7.93.D7.A4.D7.9F_.D7.9B.D7.A8.D7.95.D7.9D.2C_.D7.90.D7.93.D7.92.27.2C_.D7.A4.D7.99.D7.99.D7.A8.D7.A4.D7.95.D7.A7.D7.A1.2C_.D7.91.D7.9C.D7.99.D7.A0.D7.95.D7.A7.D7.A1:">&#x5D4;&#x5EA;&#x5E7;&#x5E0;&#x5D4; &#x5D1;&#x5D3;&#x5E4;&#x5D3;&#x5E4;&#x5DF; &#x5DB;&#x5E8;&#x5D5;&#x5DD;, &#x5D0;&#x5D3;&#x5D2;&apos;, &#x5E4;&#x5D9;&#x5D9;&#x5E8;&#x5E4;&#x5D5;&#x5E7;&#x5E1;, &#x5D1;&#x5DC;&#x5D9;&#x5E0;&#x5D5;&#x5E7;&#x5E1;:</span></h4>
<p>&#x5D9;&#x5E9; &#x5DC;&#x5E4;&#x5E2;&#x5D5;&#x5DC; &#x5DC;&#x5E4;&#x5D9; &#x5D4;&#x5DE;&#x5D3;&#x5E8;&#x5D9;&#x5DB;&#x5D9;&#x5DD; &#x5D4;&#x5E8;&#x5D2;&#x5D9;&#x5DC;&#x5D9;&#x5DD;, <br>
<a href="/wiki/%D7%94%D7%AA%D7%A7%D7%A0%D7%AA_%D7%AA%D7%A2%D7%95%D7%93%D7%94_%D7%91%D7%93%D7%A4%D7%93%D7%A4%D7%9F_%D7%9B%D7%A8%D7%95%D7%9D_%D7%91%D7%9C%D7%99%D7%A0%D7%95%D7%A7%D7%A1" title="&#x5D4;&#x5EA;&#x5E7;&#x5E0;&#x5EA; &#x5EA;&#x5E2;&#x5D5;&#x5D3;&#x5D4; &#x5D1;&#x5D3;&#x5E4;&#x5D3;&#x5E4;&#x5DF; &#x5DB;&#x5E8;&#x5D5;&#x5DD; &#x5D1;&#x5DC;&#x5D9;&#x5E0;&#x5D5;&#x5E7;&#x5E1;">&#x5D4;&#x5EA;&#x5E7;&#x5E0;&#x5EA; &#x5EA;&#x5E2;&#x5D5;&#x5D3;&#x5D4; &#x5D1;&#x5D3;&#x5E4;&#x5D3;&#x5E4;&#x5DF; &#x5DB;&#x5E8;&#x5D5;&#x5DD; &#x5D1;&#x5DC;&#x5D9;&#x5E0;&#x5D5;&#x5E7;&#x5E1;</a><br>
